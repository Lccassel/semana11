vet = []

# leitura de 10 valores distintos
while len(vet) < 10:
    valor = int(input(f"Digite o {len(vet)+1}º valor (distinto): "))

    if valor in vet:
        print("Valor repetido! Digite outro número.")
    else:
        vet.append(valor)

# mostrando valores pares e suas posições
print("\nValores pares e suas posições:")

for i in range(len(vet)):
    if vet[i] % 2 == 0:
        print(f"Valor: {vet[i]} - Posição: {i}")
