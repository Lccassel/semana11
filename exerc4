A = []

# leitura de 10 valores distintos
while len(A) < 10:
    valor = int(input(f"Digite o {len(A)+1}º valor (distinto): "))

    if valor in A:
        print("Valor repetido! Digite outro número.")
    else:
        A.append(valor)

# criando B com ordem inversa
B = A[::-1]

# resultados
print("\nVetor A:")
print(A)

print("\nVetor B (ordem inversa de A):")
print(B)
